  + cargarJugador(Orientacion): BufferedImage?
  + cargarBloque(char): BufferedImage?
}
class Ventana {
  - Ventana(): 
  - contenedor: JPanel
  - cardLayout: CardLayout
  - instancia: Ventana
  + mostrarReplay(): void
  - mostrarPantalla(String): void
  + mostrarJuego(): void
  + mostrarPasoNivel(): void
  + mostrarMenu(): void
  + mostrarGameOver(): void
  + mostrarVictoria(): void
  + getInstancia(): Ventana
  + agregarPantalla(JPanel, String): void
}
class VictoriaPanel {
  - VictoriaPanel(String): 
  - botonVolver: JButton
  - botonSalir: JButton
  - botonReproducir: JButton
  - instancia: VictoriaPanel
  + escucharBotonReproducir(ActionListener): void
  + getInstancia(String): VictoriaPanel
  + escucharBotonVolver(ActionListener): void
  + setMensaje(String): void
  + escucharBotonSalir(ActionListener): void
}
class VistaJuego {
  + VistaJuego(Tablero, Runnable, Runnable, Runnable, IMoveCallback): 
  - hudPanel: HUDPanel
  - COLOR_FONDO: Color
  - tableroPanel: TableroPanel
  - centerWrapper: JPanel
  + getTableroPanel(): TableroPanel
  + recuperarTablero(): void
  + getHudPanel(): IVistaHUD
}

Aceite               --^  ElementoBase
BaseOverlayPanel ..> UIResources : <<use>>
Bomba                --^  ItemPiso
Caja                 --|>  ElementoBase        
